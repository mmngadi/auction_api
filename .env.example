# ══════════════════════════════════════════════════════════════
#  Auction Intelligence API — Environment Configuration
#  Copy this file to .env and edit the values.
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Local Docker:  postgresql://postgres:postgres@localhost:5432/auction
# Cloud example: postgresql://user:pass@db.provider.com:5432/auction
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auction

# Docker Compose uses these to create the local postgres container.
# Ignored if you point DATABASE_URL at a cloud database.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auction
POSTGRES_PORT=5432

# ── Ollama ────────────────────────────────────────────────────
# Base URL of your Ollama instance
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Chat model — any tool-calling capable model works:
#   qwen3.5:9b, qwen3:8b, llama3.1:8b, mistral:7b, etc.
OLLAMA_CHAT_MODEL=qwen3.5:9b

# Embedding model — any Ollama embedding model works:
#   nomic-embed-text, mxbai-embed-large, all-minilm, etc.
#   ⚠ If you change this, update EMBED_DIMENSIONS to match.
OLLAMA_EMBED_MODEL=nomic-embed-text

# Dimension of the embedding model's output vectors.
# nomic-embed-text = 768, mxbai-embed-large = 1024, all-minilm = 384
EMBED_DIMENSIONS=768

OLLAMA_TIMEOUT=120
OLLAMA_NUM_PREDICT=4096

# ── API ───────────────────────────────────────────────────────
# Comma-separated API keys. Leave empty to disable auth entirely.
API_KEYS=

# Port for the FastAPI server
API_PORT=8000

# Model ID shown in /v1/models and response objects
MODEL_ID=auction-intelligence-v1

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max tool-calling loop iterations before the agent gives up
MAX_AGENT_ITERATIONS=6

# ── Query Tuning ──────────────────────────────────────────────
MAX_ROWS=500
DEFAULT_LIMIT=20
MIN_LIMIT=10
MILEAGE_TOLERANCE_KM=25000
YEAR_TOLERANCE=5